{
  "components": {
    "schemas": {
      "AssetClass": {
        "description": "`asset_class` vocabulary (design §4.2 column comment).",
        "enum": [
          "equity",
          "bond",
          "fund",
          "option",
          "crypto",
          "commodity",
          "real_estate",
          "private",
          "other"
        ],
        "type": "string"
      },
      "Currency": {
        "description": "ISO 4217 currency code (`char(3)` in DDL), uppercase on the wire — `snake_case`\nwould mangle codes. Closed set for now; extend as regimes land (visible in the\nschema snapshot).",
        "enum": [
          "EUR",
          "GBP",
          "USD"
        ],
        "type": "string"
      },
      "DisclosureRecord": {
        "description": "One canonical disclosure record (Gold `disclosure_record`, design §4.2).\n`verification_state` is present on EVERY record — honesty travels with\nthe data.",
        "properties": {
          "as_of_date": {
            "description": "Snapshot date for holdings.",
            "format": "date",
            "type": [
              "string",
              "null"
            ]
          },
          "asset_class": {
            "$ref": "#/components/schemas/AssetClass",
            "description": "Asset class vocabulary."
          },
          "asset_description_raw": {
            "description": "Asset description exactly as filed, always kept (invariant 2).",
            "type": "string"
          },
          "created_at": {
            "description": "When the record row was created.",
            "format": "date-time",
            "type": "string"
          },
          "details": {
            "description": "Contract-typed regime payload (validated per (regime, `record_type`)\nJSON Schema at promotion, invariant 5).",
            "type": "object"
          },
          "event_date": {
            "description": "Best event date: `coalesce(transaction, notified, as_of)` (generated).",
            "format": "date",
            "type": [
              "string",
              "null"
            ]
          },
          "extracted_by": {
            "description": "Parser id / model+prompt version that produced this record.",
            "type": "string"
          },
          "extraction_confidence": {
            "description": "Extractor confidence in `[0, 1]`.",
            "format": "float",
            "type": [
              "number",
              "null"
            ]
          },
          "filing_id": {
            "description": "Source filing this record came from.",
            "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "type": "string"
          },
          "fingerprint": {
            "description": "Idempotency fingerprint (audit trail).",
            "type": "string"
          },
          "id": {
            "description": "Record ULID (time-sortable; the pagination cursor).",
            "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "type": "string"
          },
          "instrument_id": {
            "description": "Resolved instrument — `null` below threshold, never guessed (invariant 3).",
            "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "type": [
              "string",
              "null"
            ]
          },
          "notified_date": {
            "description": "Date the interest/change was notified.",
            "format": "date",
            "type": [
              "string",
              "null"
            ]
          },
          "owner": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Owner",
                "description": "Whose asset (self/spouse/...)."
              }
            ]
          },
          "politician_id": {
            "description": "The politician the record concerns.",
            "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "type": "string"
          },
          "record_type": {
            "$ref": "#/components/schemas/RecordType",
            "description": "One of the four observation types."
          },
          "regime_id": {
            "description": "Disclosure regime the record was filed under.",
            "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "type": "string"
          },
          "side": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Side",
                "description": "Transaction direction; present when `record_type == transaction`."
              }
            ]
          },
          "supersedes_record_id": {
            "description": "Superseded record in a correction chain (supersede, never update).",
            "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "type": [
              "string",
              "null"
            ]
          },
          "transaction_date": {
            "description": "Date the transaction happened.",
            "format": "date",
            "type": [
              "string",
              "null"
            ]
          },
          "value": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ValueInterval",
                "description": "Declared value band; bounds are decimal STRINGS (invariant 7)."
              }
            ]
          },
          "verification_state": {
            "$ref": "#/components/schemas/VerificationState",
            "description": "Two-stage publication state (design §7.1) — on every record."
          }
        },
        "required": [
          "id",
          "filing_id",
          "politician_id",
          "regime_id",
          "asset_description_raw",
          "record_type",
          "asset_class",
          "verification_state",
          "extracted_by",
          "fingerprint",
          "details",
          "created_at"
        ],
        "type": "object"
      },
      "ErrorBody": {
        "description": "The error envelope every non-2xx response carries.",
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail",
            "description": "The error itself."
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "ErrorDetail": {
        "description": "Machine-readable error code plus a human-readable message.",
        "properties": {
          "code": {
            "description": "Stable machine-readable code (e.g. `invalid_cursor`, `not_found`).",
            "examples": [
              "invalid_cursor"
            ],
            "type": "string"
          },
          "message": {
            "description": "Human-readable explanation.",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "Owner": {
        "description": "`owner` CHECK: whose asset the record concerns. `self` is a Rust keyword,\nhence the `Self_` variant with an explicit wire rename.",
        "enum": [
          "self",
          "spouse",
          "dependent",
          "joint",
          "unknown"
        ],
        "type": "string"
      },
      "RecordPage": {
        "description": "One page of records; `next_cursor` is the last item's ULID, `null` when\nthe listing is exhausted (design §6.1: cursor pagination on ULIDs).",
        "properties": {
          "items": {
            "description": "Records in ascending ULID (= insertion-time) order.",
            "items": {
              "$ref": "#/components/schemas/DisclosureRecord"
            },
            "type": "array"
          },
          "next_cursor": {
            "description": "Pass back as `cursor` to fetch the page after this one; `null` at the end.",
            "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "items"
        ],
        "type": "object"
      },
      "RecordType": {
        "description": "`record_type` CHECK: the four observation types, one table (design D1).",
        "enum": [
          "transaction",
          "holding",
          "interest",
          "change_notification"
        ],
        "type": "string"
      },
      "Side": {
        "description": "`side` CHECK: direction of a transaction.",
        "enum": [
          "buy",
          "sell",
          "exchange"
        ],
        "type": "string"
      },
      "ValueInterval": {
        "description": "A money interval `low ..= high` in `currency`. Exact figures are `low == high`;\n`high == None` is an open-ended threshold (UK \"over £70,000\"). Construction is\nthe only door: `high < low` never exists — in memory or on the wire, because\nthe manual `Deserialize` impl funnels back through [`ValueInterval::new`].",
        "properties": {
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "high": {
            "type": [
              "string",
              "null"
            ]
          },
          "low": {
            "type": "string"
          }
        },
        "required": [
          "low",
          "currency"
        ],
        "type": "object"
      },
      "VerificationState": {
        "description": "`verification_state` CHECK: two-stage publication states (design §4.2).",
        "enum": [
          "unverified",
          "verified",
          "corrected",
          "disputed"
        ],
        "type": "string"
      }
    }
  },
  "info": {
    "description": "Worldwide politician financial-disclosure tracking. Cursor pagination on ULIDs; consistent error envelope; verification_state on every record.",
    "title": "govfolio API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/politicians/{id}/records": {
      "get": {
        "description": "# Errors\n`400` on a malformed cursor or limit; `404` for an unknown politician;\n`500` on backend failure — all in the consistent error envelope.",
        "operationId": "politician_records",
        "parameters": [
          {
            "description": "Politician ULID",
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Pagination cursor: the `id` of the last record on the previous page\n(from `next_cursor`). Pages begin strictly after it.",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
              "type": "string"
            }
          },
          {
            "description": "Page size, `1..=200`; defaults to 50.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "format": "int32",
              "maximum": 200,
              "minimum": 1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordPage"
                }
              }
            },
            "description": "One page of the politician's records; every record carries verification_state"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Malformed cursor or limit"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Unknown politician"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Internal error"
          }
        },
        "summary": "Lists one politician's disclosure records in ascending ULID order.",
        "tags": [
          "politicians"
        ]
      }
    },
    "/v1/records": {
      "get": {
        "description": "# Errors\n`400` on a malformed cursor, limit or filter; `500` on backend failure —\nall in the consistent error envelope.",
        "operationId": "list_records",
        "parameters": [
          {
            "description": "Pagination cursor: the `id` of the last record on the previous page\n(from `next_cursor`). Pages begin strictly after it.",
            "in": "query",
            "name": "cursor",
            "required": false,
            "schema": {
              "pattern": "^[0-7][0-9A-HJKMNP-TV-Z]{25}$",
              "type": "string"
            }
          },
          {
            "description": "Page size, `1..=200`; defaults to 50.",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "format": "int32",
              "maximum": 200,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Only records of this type.",
            "in": "query",
            "name": "record_type",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/RecordType"
            }
          },
          {
            "description": "Only records in this verification state.",
            "in": "query",
            "name": "verification_state",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/VerificationState"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordPage"
                }
              }
            },
            "description": "One page of disclosure records; every record carries verification_state"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Malformed cursor, limit or filter"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Internal error"
          }
        },
        "summary": "Lists disclosure records in ascending ULID order.",
        "tags": [
          "records"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Canonical disclosure records (Gold)",
      "name": "records"
    },
    {
      "description": "Politician-scoped views",
      "name": "politicians"
    }
  ]
}
